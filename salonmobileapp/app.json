{
  "expo": {
    "name": "Schedelux",
    "slug": "schedelux-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "schedelux",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFF7FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salonapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7FA"
      },
      "package": "com.salonapp.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "http://127.0.0.1:8000"
    }
  }
}
