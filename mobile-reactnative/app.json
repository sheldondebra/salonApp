{
  "expo": {
    "name": "BeautyOS",
    "slug": "salonapp-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "salonapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFF7FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salonapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF7FA"
      },
      "package": "com.salonapp.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
