APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
# Subdirectory deploy (e.g. Hostinger /salonApp): include the path — http://your-domain.com/salonApp
# Ops monitor login: {APP_URL}/ops/login  (NOT localhost:8000 on the server)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Enables parallel requests on `php artisan serve --no-reload` (required flag; default `serve` stays single-threaded).
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Ops Monitor — login at http://localhost:8000/ops (API health dashboard)
OPS_MONITOR_ENABLED=true
OPS_MONITOR_USERNAME=ops
OPS_MONITOR_PASSWORD=changeme
# OPS_MONITOR_PATH=ops
# OPS_MONITOR_RETENTION_DAYS=14

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty on Hostinger/production. Use "localhost" only for local dev (see below).
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SalonApp — Frontend & tenancy
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,workplace.localhost:3000
# Local dev only — omit or leave empty on Hostinger (wrong domain causes 419 on login)
# SESSION_DOMAIN=localhost

TENANT_ROOT_DOMAIN=localhost
TENANT_WORKPLACE_HOST=workplace.localhost
TENANT_ALLOW_UNVERIFIED_DOMAINS=true

# PostgreSQL — Docker (docker compose) or Neon (serverless)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=salonapp
# DB_USERNAME=salonapp
# DB_PASSWORD=salonapp_secret
# DB_SSLMODE=prefer
#
# Neon example (use pooler host, ssl required):
# DB_HOST=ep-xxxx-pooler.region.aws.neon.tech
# DB_SSLMODE=require

# Integrations (foundation)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

BILLING_CURRENCY=USD
BILLING_PROVIDER=paystack
FRONTEND_URL=http://localhost:3000
MNOTIFY_API_KEY=
MNOTIFY_SENDER_ID=
MNOTIFY_BASE_URL=https://api.mnotify.com/api
MNOTIFY_BALANCE_URL=https://apps.mnotify.net/smsapi/balance
ANALYTICS_ENABLED=true
